# Environment Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jobcopilot

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Gemini API (FREE - 1,500 requests/day)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API (FREE - 30 requests/min - FASTER alternative)
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter API (FREE models available, may be rate-limited)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# AI Provider Selection (gemini | groq | ollama | openrouter)
AI_PROVIDER=gemini

# CORS
CORS_ORIGIN=chrome-extension://*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Outbound Retry & Timeout (for upstream AI providers)
OUTBOUND_MAX_RETRIES=3
OUTBOUND_INITIAL_BACKOFF_MS=500
OUTBOUND_TIMEOUT_MS=30000

# Free Tier Limits
FREE_ANALYSES_PER_WEEK=5

# File Upload
MAX_FILE_SIZE=10485760

# Stripe (for payments)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Frontend URL (for redirects)
FRONTEND_URL=https://jobcopilot.ai
